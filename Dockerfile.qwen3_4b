FROM python:3.10-slim

WORKDIR /app

RUN pip install --no-cache-dir torch --index-url https://download.pytorch.org/whl/cu121

RUN pip install --no-cache-dir transformers fastapi uvicorn pillow accelerate compressed-tensors safetensors sentencepiece protobuf

COPY qwen3_4b_server.py .

EXPOSE 8100

CMD ["python", "qwen3_4b_server.py"]
