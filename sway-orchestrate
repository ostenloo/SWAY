#!/bin/bash

# SWAY Orchestrator — manages the entire workflow
# Handles: vLLM server startup, build/run phases, cleanup
#
# Usage:
#   ./sway-orchestrate build --cell b4
#   ./sway-orchestrate run --cell b4 --muts qwen,gemma,gpt-oss
#   ./sway-orchestrate eval --cell b4 --muts all
#   ./sway-orchestrate full --cell b4 --muts qwen,gemma
#   ./sway-orchestrate status
#   ./sway-orchestrate cleanup

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
HARNESS_DIR="$SCRIPT_DIR/sway_harness"
RUNNER_DIR="$SCRIPT_DIR"  # model-runner is in the same dir
MODEL_RUNNER="$RUNNER_DIR/model-runner"
CONFIG_FILE="$RUNNER_DIR/models.json"

# Logging
log() { echo "[$(date +'%Y-%m-%d %H:%M:%S')] $*"; }
err() { echo "[ERROR] $*" >&2; }

# Check prerequisites
check_prereqs() {
    if [ ! -f "$CONFIG_FILE" ]; then
        err "models.json not found in $RUNNER_DIR"
        exit 1
    fi

    if [ ! -d "$HARNESS_DIR" ]; then
        err "sway_harness directory not found"
        exit 1
    fi

    if ! command -v jq &> /dev/null; then
        err "jq is required but not installed"
        exit 1
    fi

    log "Prerequisites check: OK"
}

# Get required models for a phase
get_required_models() {
    local phase=$1
    local muts=$2

    case "$phase" in
        build)
            echo "ministral phi"  # Simulator, Fidelity Checker
            ;;
        run)
            echo "ministral phi $muts"  # Simulator, Fidelity Checker, MUT(s)
            ;;
        score)
            echo "llama4-scout"  # Judge
            ;;
        *)
            echo ""
            ;;
    esac
}

# Wait for a model server to be healthy (with timeout)
wait_for_model() {
    local model=$1
    local timeout=${2:-120}  # Default 2 minutes
    local interval=5
    local elapsed=0

    log "  Waiting for $model to be ready (timeout: ${timeout}s)..."

    while [ $elapsed -lt $timeout ]; do
        if ssh fedora "cd ~/sway-runner && ./model-runner health $model" &>/dev/null; then
            log "  ✓ $model is ready"
            return 0
        fi
        log "    Still waiting... ($elapsed/$timeout)s"
        sleep $interval
        elapsed=$((elapsed + interval))
    done

    err "$model failed to start within ${timeout}s"
    return 1
}

# Start vLLM servers
start_servers() {
    local models=$1
    local startup_timeout=${2:-180}  # Default 3 minutes per model
    log "Starting vLLM servers: $models (timeout: ${startup_timeout}s per model)"

    for model in $models; do
        if ssh fedora "cd ~/sway-runner && ./model-runner health $model" &>/dev/null; then
            log "  $model already running"
            continue
        fi

        log "  Starting $model..."
        ssh fedora "cd ~/sway-runner && ./model-runner up $model" || {
            err "Failed to start $model"
            exit 1
        }

        # Wait for the server to be healthy
        if ! wait_for_model "$model" "$startup_timeout"; then
            err "Server startup failed for $model"
            stop_servers "$models"
            exit 1
        fi
    done

    log "All servers ready"
}

# Stop vLLM servers
stop_servers() {
    local models=$1
    log "Stopping vLLM servers: $models"

    for model in $models; do
        ssh fedora "cd ~/sway-runner && ./model-runner down $model" 2>/dev/null || true
    done
}

# Run build phase
cmd_build() {
    local cell=$1
    local keep_servers=${2:-false}

    log "=== BUILD PHASE: Cell $cell ==="

    local models=$(get_required_models "build" "")
    start_servers "$models"

    log "Running build for cell $cell..."
    cd "$HARNESS_DIR"
    python main.py build --cell "$cell" || {
        err "Build failed for cell $cell"
        [ "$keep_servers" = "true" ] || stop_servers "$models"
        exit 1
    }

    [ "$keep_servers" = "true" ] || stop_servers "$models"
    log "Build complete for cell $cell"
}

# Run evaluation phase (run for one or more MUTs)
cmd_run() {
    local cell=$1
    local muts=$2
    local keep_servers=${3:-false}

    log "=== RUN PHASE: Cell $cell, MUTs: $muts ==="

    local models=$(get_required_models "run" "$muts")
    start_servers "$models"

    # Run for each MUT
    IFS=',' read -ra MUT_ARRAY <<< "$muts"
    for mut in "${MUT_ARRAY[@]}"; do
        mut=$(echo "$mut" | xargs)  # Trim whitespace
        log "Running evaluation for MUT: $mut"
        cd "$HARNESS_DIR"
        python main.py run --cell "$cell" --mut-model "$mut" || {
            err "Run failed for cell $cell, MUT $mut"
            [ "$keep_servers" = "true" ] || stop_servers "$models"
            exit 1
        }
    done

    [ "$keep_servers" = "true" ] || stop_servers "$models"
    log "Run phase complete for cell $cell"
}

# Run scoring phase
cmd_score() {
    local keep_servers=${1:-false}

    log "=== SCORE PHASE ==="

    local models=$(get_required_models "score" "")
    start_servers "$models"

    log "Scoring all collected transcripts..."
    cd "$HARNESS_DIR"
    python main.py score || {
        err "Scoring failed"
        [ "$keep_servers" = "true" ] || stop_servers "$models"
        exit 1
    }

    [ "$keep_servers" = "true" ] || stop_servers "$models"
    log "Scoring complete"
}

# Full pipeline: build → run → score
cmd_full() {
    local cell=$1
    local muts=$2

    log "=== FULL PIPELINE: Cell $cell, MUTs: $muts ==="

    # Run all phases with servers kept between them
    cmd_build "$cell" "true"
    cmd_run "$cell" "$muts" "true"
    cmd_score "false"

    log "=== PIPELINE COMPLETE ==="
}

# Show server status
cmd_status() {
    log "=== SERVER STATUS ==="
    ssh fedora "cd ~/sway-runner && ./model-runner status all"
}

# Cleanup: stop all servers
cmd_cleanup() {
    log "=== CLEANUP ==="
    local all_models=$(jq -r '.models | keys[]' "$CONFIG_FILE" | tr '\n' ' ')
    stop_servers "$all_models"
    log "Cleanup complete"
}

# Show help
show_help() {
    cat <<EOF
SWAY Orchestrator — Workflow Management

Usage: $(basename "$0") COMMAND [OPTIONS]

Commands:

  build --cell CELL
    Run build phase (prompt optimization) for a cell
    Example: ./sway-orchestrate build --cell b4

  run --cell CELL --muts MUTS
    Run evaluation phase for a cell and MUT(s)
    MUTS: comma-separated list or "all"
    Example: ./sway-orchestrate run --cell b4 --muts qwen,gemma,gpt-oss

  eval --cell CELL --muts MUTS
    Alias for 'run' (shorter typing)

  score
    Run scoring phase on all collected transcripts
    Example: ./sway-orchestrate score

  full --cell CELL --muts MUTS
    Run complete pipeline: build → run → score
    Keeps servers alive between phases for efficiency
    Example: ./sway-orchestrate full --cell b4 --muts qwen,gemma

  status
    Show vLLM server status
    Example: ./sway-orchestrate status

  cleanup
    Stop all vLLM servers
    Example: ./sway-orchestrate cleanup

Environment:
  - Assumes fedora machine is accessible via SSH (ssh fedora)
  - model-runner script must be in: $RUNNER_DIR
  - SWAY harness must be in: $HARNESS_DIR

Notes:
  - Servers are started/stopped automatically per phase
  - Use 'full' command to run multiple phases efficiently
  - Use 'status' to check which servers are running
  - Use 'cleanup' if servers don't stop properly

EOF
}

# Main
main() {
    check_prereqs

    if [ $# -lt 1 ]; then
        show_help
        exit 1
    fi

    local command=$1
    shift

    case "$command" in
        build)
            local cell=""
            while [ $# -gt 0 ]; do
                case "$1" in
                    --cell) cell=$2; shift 2 ;;
                    *) shift ;;
                esac
            done
            [ -z "$cell" ] && { err "Missing --cell"; exit 1; }
            cmd_build "$cell"
            ;;
        run|eval)
            local cell="" muts=""
            while [ $# -gt 0 ]; do
                case "$1" in
                    --cell) cell=$2; shift 2 ;;
                    --muts) muts=$2; shift 2 ;;
                    *) shift ;;
                esac
            done
            [ -z "$cell" ] && { err "Missing --cell"; exit 1; }
            [ -z "$muts" ] && { err "Missing --muts"; exit 1; }
            cmd_run "$cell" "$muts"
            ;;
        score)
            cmd_score
            ;;
        full)
            local cell="" muts=""
            while [ $# -gt 0 ]; do
                case "$1" in
                    --cell) cell=$2; shift 2 ;;
                    --muts) muts=$2; shift 2 ;;
                    *) shift ;;
                esac
            done
            [ -z "$cell" ] && { err "Missing --cell"; exit 1; }
            [ -z "$muts" ] && { err "Missing --muts"; exit 1; }
            cmd_full "$cell" "$muts"
            ;;
        status)
            cmd_status
            ;;
        cleanup)
            cmd_cleanup
            ;;
        help|-h|--help)
            show_help
            ;;
        *)
            err "Unknown command: $command"
            show_help
            exit 1
            ;;
    esac
}

main "$@"
