#!/bin/bash
# Llama 3.1 8B server using Transformers library

NAME="llama-3.1-8b"
IMAGE_NAME="llama-transformers"

case "$1" in
  build)
    echo "Building Docker image..."
    docker build -f Dockerfile.llama -t "$IMAGE_NAME" .
    ;;

  up)
    if docker ps -a --format '{{.Names}}' | grep -q "^$NAME$"; then
      echo "Starting existing container..."
      docker start "$NAME"
    else
      echo "Container not found. Building and starting..."
      docker rm -f "$NAME" 2>/dev/null

      docker run -d --name "$NAME" --restart unless-stopped --gpus all --ipc=host \
        -v /mnt/data:/mnt/data \
        -p 8020:8020 \
        "$IMAGE_NAME"
    fi

    echo "Container $NAME started on port 8020"
    ;;

  down)
    docker stop "$NAME"
    ;;

  restart)
    docker restart "$NAME"
    ;;

  logs)
    docker logs -f "$NAME"
    ;;

  status)
    docker ps -a --filter "name=$NAME"
    ;;

  health)
    if curl -s http://localhost:8020/v1/models >/dev/null 2>&1; then
      echo "✓ Llama API is responding"
    else
      echo "✗ Llama API is not responding"
      exit 1
    fi
    ;;

  *)
    echo "Usage: $0 {build|up|down|restart|logs|status|health}"
    ;;
esac
